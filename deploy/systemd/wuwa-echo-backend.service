[Unit]
Description=Wuwa Echo Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/wuwa/echo/backend
EnvironmentFile=-/root/wuwa/echo/backend/.env
ExecStart=/root/wuwa/echo/backend/bin/wuwa-echo-backend
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
